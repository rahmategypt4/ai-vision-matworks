# ── OpenAI ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── SerpAPI (Google Shopping market price lookup) ───────
SERPAPI_API_KEY=

# ── MySQL ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=gemini_user
DB_PASSWORD=your_password_here
DB_NAME=gemini_vision

# ── AWS S3 (set USE_S3=true in production) ─────────────
USE_S3=false
S3_BUCKET=gemini-vision-images
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Server ──────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info
NODE_ENV=development

# ── CORS ────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
